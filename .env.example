# YouTube Data API v3 key (required)
VITE_YOUTUBE_API_KEY=

# Backend Cloudflare Worker URL (optional, defaults to localhost:8787 in dev)
VITE_BACKEND_URL=

# URL for the manage subscription page (optional)
VITE_MANAGE_SUBSCRIPTION_URL=

# Paddle client-side token (Paddle dashboard → Developer Tools → Authentication → client token)
VITE_PADDLE_CLIENT_TOKEN=

# Paddle price IDs (Paddle dashboard → Catalog → Products → your product → Prices)
VITE_PADDLE_PRICE_ID_MONTHLY=
VITE_PADDLE_PRICE_ID_YEARLY=

# Paddle environment: "production" or "sandbox" (default: production)
VITE_PADDLE_ENV=production
