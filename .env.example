# YouTube Data API v3 key (required)
VITE_YOUTUBE_API_KEY=

# Backend Cloudflare Worker URL (optional, defaults to localhost:8787 in dev)
VITE_BACKEND_URL=

# URL for the manage subscription page (optional)
VITE_MANAGE_SUBSCRIPTION_URL=

# Paddle hosted checkout page URL (get from Paddle dashboard → Checkout → Links)
VITE_PADDLE_CHECKOUT_URL=
