# PostgreSQL connection string (required)
DATABASE_URL=

# Set to "true" if your database requires SSL (e.g. Render, Railway, Supabase)
DATABASE_SSL=true

# Paddle API key — Customers:read + Subscriptions:read scopes (required)
# Set this in your hosting dashboard (Render, Railway, etc.) — never commit the real key
PADDLE_API_KEY=

# Paddle environment base URL
# Production: https://api.paddle.com
# Sandbox:    https://sandbox-api.paddle.com
PADDLE_API_BASE=https://api.paddle.com

# Paddle webhook signing secret (Paddle dashboard → Notifications → your endpoint → secret key)
PADDLE_WEBHOOK_SECRET=

# Postmark — for sending restore-code emails (required)
POSTMARK_API_TOKEN=
POSTMARK_FROM=support@galactosegalaxy.com

# Secret used to HMAC-hash restore codes (required — any long random string)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RESTORE_CODE_SECRET=

# Set to "true" to enable the /debug/simulate-webhook endpoint (never use in production)
DEBUG_MODE=false
